# Copy to .env and fill in your Auth0 domain
# Found in Auth0 Dashboard → Applications → your app → Settings → Domain
VITE_AUTH0_DOMAIN=YOUR_AUTH0_DOMAIN_HERE
VITE_AUTH0_CLIENT_ID=CIRGWlat031QliQpWGZtdnORr3MYauiR

# Set to "true" to show fit-percentage badges on job cards and auto-sort
# results from highest match to lowest. Set to "false" to hide them.
VITE_PERCENTAGE_ENABLE=true
