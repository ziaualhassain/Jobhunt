# Copy this file to .env and fill in your values

# ── Claude API (optional — one of the two AI options below) ─────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (optional — free local AI, no account needed) ────────────────────
# Install: https://ollama.com  |  Mac: brew install ollama
# Pull a model: ollama pull llama3.2
# Run: ollama serve
# The app auto-detects Ollama — no env var needed unless you want a custom setup.
OLLAMA_MODEL=llama3.2
OLLAMA_URL=http://localhost:11434

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
