# Copy this file to .env and fill in your values

# ── PostgreSQL (Aiven) ───────────────────────────────────────────────────────
DB_HOST=pg-jobhunt-ziaualhassain-a7b1.d.aivencloud.com
DB_PORT=25881
DB_USER=avnadmin
DB_PASSWORD=your-db-password-here
DB_NAME=defaultdb

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string

# ── Claude API (optional — one of the two AI options below) ─────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── AI backend selection ─────────────────────────────────────────────────────
# true  → Anthropic API (requires ANTHROPIC_API_KEY above)
# false → local Ollama model
# omit  → auto: API if key present, otherwise Ollama (backward-compatible default)
#
# USE_API_FOR_AUTO_APPLY — controls the auto-apply browser agent
# USE_API               — controls everything else (resume, interview, prep, deep score)
USE_API_FOR_AUTO_APPLY=true
USE_API=true

# ── Ollama (optional — free local AI, no account needed) ────────────────────
# Install: https://ollama.com  |  Mac: brew install ollama
# The app auto-detects Ollama when ANTHROPIC_API_KEY is not set.
#
# IMPORTANT: the model MUST support tool calling. Confirmed working models:
#   llama3.2:1b  (~1.3 GB, lightest, good for testing)
#   llama3.1     (~8 GB, smarter but heavy on RAM)
#   mistral      (~4 GB, good balance)
#   qwen2.5      (~4 GB, strong at forms)
#
# Models that do NOT support tools (will get 400 error): phi3, tinyllama
#
# Pull your chosen model first:  ollama pull qwen2.5
OLLAMA_MODEL=qwen2.5
OLLAMA_BASE_URL=http://localhost:11434

# ── TheirStack (optional — adds more job listings) ───────────────────────────
# Sign up at https://theirstack.com to get a key
THEIRSTACK_API_KEY=
# Set to true to refresh TheirStack jobs from the API on startup (every 6 h).
# Set to false to skip the API sync and serve only existing DB rows.
REFRESH_THEIRSTACK=true

# ── Auth0 (optional — enables social login: Google, GitHub, etc.) ────────────
# Create a Single Page Application at https://manage.auth0.com → Applications
# Domain is on the app's Settings page (e.g. dev-xxxxxxxx.us.auth0.com)
AUTH0_DOMAIN=YOUR_AUTH0_DOMAIN_HERE
AUTH0_CLIENT_ID=CIRGWlat031QliQpWGZtdnORr3MYauiR
AUTH0_CLIENT_SECRET=your-auth0-client-secret-here

# ── Credential Encryption (AES-256-GCM) ─────────────────────────────────────
# Generate a 32-byte hex key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production. The dev placeholder is intentionally weak — never use in production.
CREDENTIALS_ENCRYPTION_KEY=<32-byte hex string>

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
